from flask import Flask, send_from_directory, request, redirect, jsonify
from flask_jwt_extended import JWTManager, verify_jwt_in_request, get_jwt
from config import JWT_SECRET_KEY, JWT_ACCESS_TOKEN_EXPIRES, BASE_DIR, PROJECT_DIR, DB_PATH
import os, re, time, sqlite3

# 初始化Flask应用
app = Flask(__name__, static_folder=os.path.join(PROJECT_DIR, 'frontend', 'dist'))

# 启动时自动初始化/迁移数据库
from init_db import init_db
init_db()

# 启用 SQLite WAL 模式以提高并发性能
with sqlite3.connect(DB_PATH) as conn:
    conn.execute('PRAGMA journal_mode=WAL;')
    conn.execute('PRAGMA synchronous=NORMAL;')
app.config['JWT_SECRET_KEY'] = JWT_SECRET_KEY
app.config['JWT_ACCESS_TOKEN_EXPIRES'] = JWT_ACCESS_TOKEN_EXPIRES

jwt = JWTManager(app)

# 注册中间件：全局授权检查
from middleware.license import check_license
from models.user import UserModel

@app.before_request
def before_request():
    result = check_license()
    if result:
        return result
    
    # 单点登录验证：后登录的踢掉先登录的（登录接口不执行，避免旧 token 干扰）
    if request.path.startswith('/api/auth/login'):
        return
    auth_header = request.headers.get('Authorization', '')
    if auth_header.startswith('Bearer '):
        try:
            verify_jwt_in_request()
            jwt_data = get_jwt()
            session_id = jwt_data.get('session_id')
            user_id = jwt_data.get('sub')
            if session_id and user_id:
                user = UserModel.get_by_id(int(user_id))
                if user and user.get('session_id') and user.get('session_id') != session_id:
                    print(f'[SSO] session mismatch: user={user_id}, path={request.path}, token_session={session_id}, db_session={user.get("session_id")}')
                    return jsonify({'code': 401, 'message': '您的账号已在其他地方登录，请重新登录'}), 401
        except Exception:
            # JWT 验证异常由端点各自的 @jwt_required 处理
            pass

