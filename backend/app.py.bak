@app.route('/reset')
def reset_cache():
    """强制刷新页面，绕过浏览器缓存"""
    return '''
    <!DOCTYPE html>
    <html>
    <head>
        <meta charset="UTF-8">
        <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate">
        <title>清除缓存</title>
    </head>
    <body>
        <p>正在清除缓存并刷新...</p>
        <script>
            if (window.caches) {
                caches.keys().then(function(names) {
                    return Promise.all(names.map(function(name) { return caches.delete(name); }));
                }).then(function() {
                    location.href = "/?_=" + Date.now();
                }).catch(function() {
                    location.href = "/?_=" + Date.now();
                });
            } else {
                location.href = "/?_=" + Date.now();
            }
        </script>
    </body>
    </html>
    '''

# 静态文件服务：前端打包后的dist目录
@app.route('/', defaults={'path': ''})
@app.route('/<path:path>')
def serve_frontend(path):
    dist_dir = os.path.join(PROJECT_DIR, 'frontend', 'dist')
    # 强制给 URL 添加时间戳参数，彻底绕过 Safari 磁盘缓存（排除 API 和静态资源）
    if not request.args.get('_') and not path.startswith(('api/', 'assets/', 'favicon.')):
        return redirect(f'{request.path}?_={int(time.time())}', code=302)
    if path and os.path.exists(os.path.join(dist_dir, path)):
        response = send_from_directory(dist_dir, path)
        response.headers['Cache-Control'] = 'no-cache, must-revalidate'
        return response
    # assets 下的文件不存在时返回 404，避免返回 HTML 导致 MIME 类型错误
    if path.startswith('assets/'):
        return 'Not Found', 404
    # 读取 index.html 并注入缓存控制脚本，强制浏览器重新加载
    index_path = os.path.join(dist_dir, 'index.html')
    with open(index_path, 'r', encoding='utf-8') as f:
        html = f.read()
    _v = str(int(time.time()))
    html = re.sub(r'(src="/assets/[^"]+)(")', r'\1?v=' + _v + r'\2', html)
    html = re.sub(r'(href="/assets/[^"]+)(")', r'\1?v=' + _v + r'\2', html)
    # 注入 chunk 404 自动刷新脚本（放在 </head> 前）
    refresh_script = '''<script>(function(){var r=false;window.addEventListener('error',function(e){if(e.target&&e.target.tagName==='SCRIPT'&&e.target.src&&e.target.src.indexOf('/assets/')!==-1){if(!r){r=true;location.href=location.pathname+'?_='+Date.now();}}},true);window.addEventListener('unhandledrejection',function(e){var s=e.reason&&e.reason.stack||'';if(s.indexOf('Importing a module script failed')!==-1||s.indexOf('dynamically imported module')!==-1){if(!r){r=true;location.href=location.pathname+'?_='+Date.now();}}});})();</script>'''
    html = html.replace('</head>', refresh_script + '</head>')
    response = app.make_response(html)
    response.headers['Content-Type'] = 'text/html; charset=utf-8'
    response.headers['Cache-Control'] = 'no-store, no-cache, must-revalidate, max-age=0'
    response.headers['Pragma'] = 'no-cache'
    response.headers['Expires'] = '0'
    response.headers['Vary'] = '*'
    return response

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5001, debug=False)
